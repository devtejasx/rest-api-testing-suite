// Prisma schema for the REST API Testing Suite backend.
// Datasource: PostgreSQL. Client: prisma-client-js.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Application users. Passwords are stored as bcrypt hashes.
model User {
  id            String         @id @default(uuid())
  name          String
  email         String         @unique
  password      String
  role          Role           @default(VIEWER)
  createdAt     DateTime       @default(now())

  refreshTokens RefreshToken[]

  @@map("users")
}

/// Hashed, rotatable refresh tokens (Feature 7).
model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

/// A Postman-style collection of API requests + tests.
model Collection {
  id            String      @id @default(uuid())
  name          String
  description   String      @default("")
  totalRequests Int         @default(0)
  totalTests    Int         @default(0)
  createdAt     DateTime    @default(now())

  executions    Execution[]

  @@map("collections")
}

/// A single run of a collection.
model Execution {
  id         String          @id @default(uuid())
  collectionId String
  status     ExecutionStatus @default(RUNNING)
  duration   Int             @default(0) // milliseconds
  startedAt  DateTime        @default(now())
  finishedAt DateTime?

  collection Collection      @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  results    RequestResult[]
  report     Report?

  @@index([collectionId])
  @@index([status])
  @@map("executions")
}

/// The result of a single request within an execution.
model RequestResult {
  id           String   @id @default(uuid())
  executionId  String
  name         String   @default("") // Postman request name
  endpoint     String
  method       String
  statusCode   Int
  responseTime Int // milliseconds
  passed       Boolean  @default(false)
  errorMessage String? // assertion failure detail, if any

  execution    Execution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([executionId])
  @@map("request_results")
}

/// Aggregated report for one execution.
model Report {
  id                  String   @id @default(uuid())
  executionId         String   @unique
  totalTests          Int      @default(0)
  passed              Int      @default(0)
  failed              Int      @default(0)
  averageResponseTime Float    @default(0)
  reportPath          String? // relative path to the generated HTML report

  execution           Execution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@map("reports")
}

/// Persisted application logs (Feature 12): API requests, auth, executions, errors.
model Log {
  id        String   @id @default(uuid())
  level     String   @default("info") // info | warn | error
  type      String   @default("SYSTEM") // REQUEST | AUTH | EXECUTION | ERROR | SYSTEM
  message   String
  createdAt DateTime @default(now())

  @@index([type])
  @@index([createdAt])
  @@map("logs")
}

enum Role {
  USER
  ADMIN
  TESTER
  VIEWER
}

enum ExecutionStatus {
  RUNNING
  SUCCESS
  FAILED
}
