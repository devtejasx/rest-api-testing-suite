# ─────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8080

# Comma-separated list of allowed CORS origins (the frontend dev server).
CORS_ORIGIN=http://localhost:5173

# ─────────────────────────────────────────────────────────────
# Database (PostgreSQL)
# ─────────────────────────────────────────────────────────────
# When running locally without Docker, point this at your local Postgres.
# When running via docker-compose, the host is the "db" service name.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rats?schema=public

# ─────────────────────────────────────────────────────────────
# Auth (JWT)
# ─────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=10

# ─────────────────────────────────────────────────────────────
# Rate limiting
# ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# ─────────────────────────────────────────────────────────────
# Seed admin credentials
# ─────────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@rats.dev
SEED_ADMIN_PASSWORD=Admin@12345
